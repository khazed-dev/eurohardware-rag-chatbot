{
  "name": "eurohardware-rag-chatbot",
  "version": "1.0.0",
  "description": "RAG chatbot backend for Euro Hardware website using Ollama embeddings, Supabase pgvector and Groq answer generation",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "crawl": "node -e \"import('./crawler.js').then(({ crawlWebsite }) => crawlWebsite().then((stats) => console.log(JSON.stringify(stats, null, 2))))\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
